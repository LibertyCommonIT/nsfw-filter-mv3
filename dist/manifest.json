{
  "name": "The Dress Code Enforcer",
  "version": "1.0.0",
  "description": "Free, open source, and privacy-focused browser extension to aggressively block \"not safe for school\" content.",
  "author": "Liberty IT Team & Tim Wildig",
  "homepage_url": "https://nsfw-filter.com",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "offscreen",
    "tabs",
    "management"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["src/content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "NSFW Filter",
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["models/*", "models/inceptionv3/*", "images/*", "config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
